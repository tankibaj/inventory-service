    "/api/v1/products": {
      "get": {
        "tags": [
          "products"
        ],
        "summary": "List Products",
        "operationId": "list_products_api_v1_products_get",
        "parameters": [
          {
            "name": "in_stock_only",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "In Stock Only"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "title": "Page"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "default": 20,
              "title": "Per Page"
            }
          },
          {
            "name": "x-tenant-id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "title": "X-Tenant-Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductPage"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "products"
        ],
        "summary": "Create Product",
        "operationId": "create_product_api_v1_products_post",
        "parameters": [
          {
            "name": "x-tenant-id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "title": "X-Tenant-Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProductRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductSchema"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/products/{product_id}": {
      "get": {
        "tags": [
          "products"
        ],
        "summary": "Get Product",
        "operationId": "get_product_api_v1_products__product_id__get",
        "parameters": [
          {
            "name": "product_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Product Id"
            }
          },
          {
            "name": "x-tenant-id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "title": "X-Tenant-Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductSchema"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stock/{sku_id}": {
      "get": {
        "tags": [
          "stock"
        ],
        "summary": "Get Stock Level",
        "operationId": "get_stock_level_api_v1_stock__sku_id__get",
        "parameters": [
          {
            "name": "sku_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Sku Id"
            }
          },
          {
            "name": "x-tenant-id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "title": "X-Tenant-Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StockLevelSchema"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stock/reserve": {
      "post": {
        "tags": [
          "stock"
        ],
        "summary": "Reserve Stock",
        "operationId": "reserve_stock_api_v1_stock_reserve_post",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Idempotency-Key"
            }
          },
          {
            "name": "x-tenant-id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "title": "X-Tenant-Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReserveStockRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "$ref": "#/components/schemas/ReserveStockResponse"
                    },
                    {
                      "$ref": "#/components/schemas/StockConflictError"
                    }
                  ],
                  "title": "Response Reserve Stock Api V1 Stock Reserve Post",
                  "$ref": "#/components/schemas/ReserveStockResponse"
                }
              }
            }
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StockConflictError"
                }
              }
            },
            "description": "Conflict"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stock/deduct": {
      "post": {
        "tags": [
          "stock"
        ],
        "summary": "Deduct Stock",
        "operationId": "deduct_stock_api_v1_stock_deduct_post",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Idempotency-Key"
            }
          },
          {
            "name": "x-tenant-id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "title": "X-Tenant-Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeductStockRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stock/reservations/{reservation_id}/release": {
      "post": {
        "tags": [
          "stock"
        ],
        "summary": "Release Reservation",
        "operationId": "release_reservation_api_v1_stock_reservations__reservation_id__release_post",
        "parameters": [
          {
            "name": "reservation_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Reservation Id"
            }
          },
          {
            "name": "x-tenant-id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "title": "X-Tenant-Id"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateProductRequest": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 200,
            "minLength": 1,
            "title": "Name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 2000
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "image_url": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 500
              },
              {
                "type": "null"
              }
            ],
            "title": "Image Url"
          },
          "skus": {
            "items": {
              "$ref": "#/components/schemas/CreateSKURequest"
            },
            "type": "array",
            "minItems": 1,
            "title": "Skus"
          }
        },
        "type": "object",
        "required": [
          "name",
          "skus"
        ],
        "title": "CreateProductRequest"
      },
      "CreateSKURequest": {
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "title": "Label"
          },
          "price_minor": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Price Minor"
          },
          "initial_stock": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Initial Stock"
          }
        },
        "type": "object",
        "required": [
          "label",
          "price_minor",
          "initial_stock"
        ],
        "title": "CreateSKURequest"
      },
      "DeductStockRequest": {
        "properties": {
          "reservation_id": {
            "type": "string",
            "format": "uuid",
            "title": "Reservation Id"
          }
        },
        "type": "object",
        "required": [
          "reservation_id"
        ],
        "title": "DeductStockRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PaginationMeta": {
        "properties": {
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "page": {
            "type": "integer",
            "title": "Page"
          },
          "per_page": {
            "type": "integer",
            "title": "Per Page"
          }
        },
        "type": "object",
        "required": [
          "total",
          "page",
          "per_page"
        ],
        "title": "PaginationMeta"
      },
      "ProductPage": {
        "properties": {
          "data": {
            "items": {
              "$ref": "#/components/schemas/ProductSchema"
            },
            "type": "array",
            "title": "Data"
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        },
        "type": "object",
        "required": [
          "data",
          "meta"
        ],
        "title": "ProductPage"
      },
      "ProductSchema": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "image_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Image Url"
          },
          "skus": {
            "items": {
              "$ref": "#/components/schemas/SKUSchema"
            },
            "type": "array",
            "title": "Skus"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "skus",
          "created_at"
        ],
        "title": "ProductSchema"
      },
      "ReserveLineRequest": {
        "properties": {
          "sku_id": {
            "type": "string",
            "format": "uuid",
            "title": "Sku Id"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Quantity"
          }
        },
        "type": "object",
        "required": [
          "sku_id",
          "quantity"
        ],
        "title": "ReserveLineRequest"
      },
      "ReserveStockRequest": {
        "properties": {
          "order_id": {
            "type": "string",
            "format": "uuid",
            "title": "Order Id"
          },
          "lines": {
            "items": {
              "$ref": "#/components/schemas/ReserveLineRequest"
            },
            "type": "array",
            "minItems": 1,
            "title": "Lines"
          }
        },
        "type": "object",
        "required": [
          "order_id",
          "lines"
        ],
        "title": "ReserveStockRequest"
      },
      "ReserveStockResponse": {
        "properties": {
          "reservation_id": {
            "type": "string",
            "format": "uuid",
            "title": "Reservation Id"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "title": "Expires At"
          }
        },
        "type": "object",
        "required": [
          "reservation_id",
          "expires_at"
        ],
        "title": "ReserveStockResponse"
      },
      "SKUSchema": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "price_minor": {
            "type": "integer",
            "title": "Price Minor"
          },
          "stock_level": {
            "type": "integer",
            "title": "Stock Level"
          }
        },
        "type": "object",
        "required": [
          "id",
          "label",
          "price_minor",
          "stock_level"
        ],
        "title": "SKUSchema"
      },
      "StockConflict": {
        "properties": {
          "sku_id": {
            "type": "string",
            "format": "uuid",
            "title": "Sku Id"
          },
          "requested": {
            "type": "integer",
            "title": "Requested"
          },
          "available": {
            "type": "integer",
            "title": "Available"
          }
        },
        "type": "object",
        "required": [
          "sku_id",
          "requested",
          "available"
        ],
        "title": "StockConflict"
      },
      "StockConflictError": {
        "properties": {
          "code": {
            "type": "string",
            "title": "Code",
            "default": "STOCK_CONFLICT"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "conflicts": {
            "items": {
              "$ref": "#/components/schemas/StockConflict"
            },
            "type": "array",
            "title": "Conflicts"
          }
        },
        "type": "object",
        "required": [
          "message",
          "conflicts"
        ],
        "title": "StockConflictError"
      },
      "StockLevelSchema": {
        "properties": {
          "sku_id": {
            "type": "string",
            "format": "uuid",
            "title": "Sku Id"
          },
          "available": {
            "type": "integer",
            "title": "Available"
          },
          "reserved": {
            "type": "integer",
            "title": "Reserved"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          }
        },
        "type": "object",
        "required": [
          "sku_id",
          "available",
          "reserved",
          "total"
        ],
        "title": "StockLevelSchema"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
